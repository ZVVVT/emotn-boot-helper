<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:label="Emotn 开机助手"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Translucent.NoTitleBar">

        <!--
          v1.5: automatic receiver/service run under a custom process name.
          TV Manager's DoneRemoteBlacklist incorrectly treats a missing package
          lookup as a system application and therefore skips force-stop.
          The APK package name/applicationId remains com.zvvvt.emotnboot.
        -->
        <receiver
            android:name=".BootReceiver"
            android:process="com.zvvvt.emotnwatch"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.REBOOT" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.dangbei.action.STR_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".WakeWatchService"
            android:process="com.zvvvt.emotnwatch"
            android:enabled="true"
            android:exported="false"
            android:stopWithTask="false" />

        <!-- Automatic boot/wake path does not invoke this activity since v1.4. -->
        <activity
            android:name=".LaunchActivity"
            android:enabled="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:finishOnTaskLaunch="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
    </application>

</manifest>
